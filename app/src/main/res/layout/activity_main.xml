<?xml version="1.0" encoding="utf-8"?>
<!--
    SwipeRefreshLayout envuelve todo el contenido para permitir
    actualización manual deslizando hacia abajo.
-->
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/swipeRefreshLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#121212"
        tools:context=".ui.MainActivity">

        <!-- ═══════════════════════════════════════════════════════ HEADER -->

        <TextView
            android:id="@+id/tvHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BetMaster AI"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            app:layout_constraintEnd_toStartOf="@+id/progressBar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintHorizontal_bias="0.5" />

        <!-- Spinner de carga (visible solo mientras se actualiza) -->
        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleSmall"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginStart="10dp"
            android:indeterminateTint="#BB86FC"
            android:visibility="gone"
            app:layout_constraintStart_toEndOf="@+id/tvHeader"
            app:layout_constraintTop_toTopOf="@+id/tvHeader"
            app:layout_constraintBottom_toBottomOf="@+id/tvHeader"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0" />

        <!-- ══════════════════════════════════════════════ BARRA DE ESTADO -->

        <!--
            Muestra el estado de la última actualización:
              "✓ En vivo · The Odds API · 14:32:01"
              "⚠ Sin conexión (datos demo)"
              "Actualizando…"
        -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginHorizontal="16dp"
            android:gravity="center"
            android:textColor="#888888"
            android:textSize="11sp"
            android:singleLine="true"
            android:ellipsize="end"
            tools:text="✓ En vivo · The Odds API · 14:32:01"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvHeader" />

        <!-- ════════════════════════════════════════ GRÁFICO DE BANKROLL -->

        <TextView
            android:id="@+id/tvBankrollTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:layout_marginStart="16dp"
            android:text="Evolución del Bankroll"
            android:textColor="#BB86FC"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvStatus" />

        <com.github.mikephil.charting.charts.LineChart
            android:id="@+id/bankrollChart"
            android:layout_width="0dp"
            android:layout_height="185dp"
            android:layout_marginTop="6dp"
            android:layout_marginHorizontal="16dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvBankrollTitle" />

        <!-- ══════════════════════════════════════════════ LISTA PARTIDOS -->

        <TextView
            android:id="@+id/tvMatchesTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginStart="16dp"
            android:text="Partidos de Hoy"
            android:textColor="#BB86FC"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/bankrollChart" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvMatches"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvMatchesTitle" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
