<?xml version="1.0" encoding="utf-8"?>
<!--
    Formulario para registrar una apuesta.
    El usuario llega aquí al presionar "Apostar" en una card de partido.

    Datos que recibe vía Intent (extras):
      - "match_details"   → String  ("Real Madrid vs Man City")
      - "expected_value"  → double  (EV calculado por BetEngine)
      - "suggested_bet"   → double  (monto sugerido por Half Kelly)
      - "home_odds"       → double  (cuota del equipo local)
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ═══════════════════════════════════════════════════════ HEADER -->

        <TextView
            android:id="@+id/tvBetTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:text="@string/bet_title"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvBetSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="20dp"
            android:text="@string/bet_subtitle"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

        <!-- ══════════════════════════════════════════════ CARD DEL PARTIDO -->

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#1E1E1E"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            app:strokeColor="#BB86FC"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Etiqueta de sección -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PARTIDO"
                    android:textColor="#BB86FC"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12" />

                <!-- Nombre del partido (viene del Intent) -->
                <TextView
                    android:id="@+id/tvMatchDetails"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    tools:text="Real Madrid vs Man City" />

                <!-- Divisor -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp"
                    android:background="#333333" />

                <!-- Fila: EV y Cuota Local -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <!-- EV -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="VALOR ESPERADO (EV)"
                            android:textColor="#888888"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvEV"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:textColor="#03DAC5"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            tools:text="+0.14" />
                    </LinearLayout>

                    <!-- Cuota -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CUOTA LOCAL"
                            android:textColor="#888888"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvOdds"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:textColor="#BB86FC"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            tools:text="2.10" />
                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ═══════════════════════════════════════════ CARD DEL FORMULARIO -->

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#1E1E1E"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            app:strokeColor="#333333"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Etiqueta de sección -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DETALLES DE LA APUESTA"
                    android:textColor="#BB86FC"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="12dp" />

                <!-- Monto sugerido por Kelly (informativo) -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="#2A2A2A"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#444444"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="12dp"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_menu_info_details"
                            app:tint="#03DAC5" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="10dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Monto sugerido por Kelly (Half Kelly)"
                                android:textColor="#888888"
                                android:textSize="11sp" />

                            <TextView
                                android:id="@+id/tvSuggestedBet"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:textColor="#03DAC5"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                tools:text="$50.00" />
                        </LinearLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Campo: Monto real que quiere apostar -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilActualBet"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="Monto a apostar ($)"
                    app:boxBackgroundColor="#2A2A2A"
                    app:boxStrokeColor="#BB86FC"
                    app:boxStrokeWidthFocused="2dp"
                    app:hintTextColor="#BB86FC"
                    app:prefixText="$"
                    app:prefixTextColor="#888888"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etActualBet"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#555555"
                        android:textSize="16sp"
                        tools:text="50.00" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Etiqueta: Seleccionar resultado -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:text="Estado inicial de la apuesta"
                    android:textColor="#888888"
                    android:textSize="13sp" />

                <!-- RadioGroup para el resultado -->
                <RadioGroup
                    android:id="@+id/rgResult"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <!-- PENDING -->
                    <RadioButton
                        android:id="@+id/rbPending"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:checked="true"
                        android:text="Pendiente"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:buttonTint="#BB86FC" />

                    <!-- WON -->
                    <RadioButton
                        android:id="@+id/rbWon"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Ganada ✓"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:buttonTint="#00C853" />

                    <!-- LOST -->
                    <RadioButton
                        android:id="@+id/rbLost"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Perdida ✗"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:buttonTint="#D50000" />

                </RadioGroup>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ═══════════════════════════════════════════════════════ BOTONES -->

        <!-- Botón principal: Guardar -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveBet"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="12dp"
            android:text="Guardar Apuesta"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            app:backgroundTint="#BB86FC"
            app:cornerRadius="12dp"
            app:rippleColor="#9A67EA" />

        <!-- Botón secundario: Cancelar -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancel"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="8dp"
            android:text="Cancelar"
            android:textSize="16sp"
            android:textColor="#BB86FC"
            app:backgroundTint="@android:color/transparent"
            app:cornerRadius="12dp"
            app:strokeColor="#BB86FC"
            app:strokeWidth="1dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

    </LinearLayout>
</ScrollView>
